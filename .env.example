# Copy this to .env.local and fill in your values.

# Base URL of the Ozichat backend, INCLUDING the /api/v1 prefix.
# Used by both the mobile app and the admin web panel.
# When admin is deployed on the same host as the API and reverse-proxied,
# you can leave this empty and the admin will use relative paths.
API_BASE_URL=http://ozichats.com:8080/api/v1

# Used by the mobile app's Gemini-powered features (not needed for admin).
GEMINI_API_KEY=
